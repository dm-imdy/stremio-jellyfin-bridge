# ==========================================
# STREMIO-JELLYFIN BRIDGE CONFIGURATION
# ==========================================

# ==========================================
# SYSTEM SETTINGS
# ==========================================
# Server Timezone (Format: Region/City)
# Find your exact timezone here: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/New_York

# Run the container as this host user/group, so subtitle files the bridge
# places are owned by you (not root). Find yours on the host with:
#   id -u    (PUID)     id -g    (PGID)
# The folder pointed to by LOCAL_SUBS_DIR must be writable by this uid/gid.
# Left unset, the container runs as root (0:0) — unchanged from before.
PUID=1000
PGID=1000

# ==========================================
# JELLYFIN SETTINGS
# ==========================================
# Your local Jellyfin Server URL (Do not include a trailing slash)
JELLYFIN_URL=http://192.168.X.X:8096

# API Key generated from Jellyfin Dashboard -> Advanced -> API Keys
JELLYFIN_API_KEY=your_api_key_here

# The specific Jellyfin user the bridge will act as
JELLYFIN_USER_NAME=your_username

# ==========================================
# ADDON PREFERENCES
# ==========================================
# Set to 'false' to hide Jellyfin catalogs from Stremio's Discover page
# (Your media will still be searchable)
SHOW_CATALOG=true

# The default language code for subtitles files without proper naming convention
JELLYFIN_DEFAULT_EXT_SUBS_LANG=eng

# ------------------------------------------------------------------
# STANDALONE SUBTITLES (optional)
# ------------------------------------------------------------------
# Serve your own subtitle files independently of Jellyfin's media, matched to
# any title by its IMDb id (works for Jellyfin and Cinemeta titles alike).
#
# ONE setting controls everything: LOCAL_SUBS_DIR = the folder where your
# subtitle files live. Leave it UNSET to disable the feature entirely
# (no change to current behaviour).
#
# Files are organized one folder per title, e.g.:
#   movie/tt0133093.The Matrix/eng.srt
#   series/tt0903747.Breaking Bad/S01E05.eng.srt
# The full folder & naming rules are documented in subs/README.txt.
#
# LOCAL_SUBS_DIR=/home/me/subtitles

# Optional shared secret for the subtitle WRITE endpoint (POST /local-subtitle).
# If set, write requests must echo it back in an X-Write-Secret header; if unset,
# any LAN client may write. Keep this endpoint LAN-only regardless.
# LOCAL_SUBS_WRITE_SECRET=some-long-random-string

# ==========================================
# NETWORK PORTS
# ==========================================
# Internal ports used by the Node server
PORT=7000
HTTPS_PORT=7001
