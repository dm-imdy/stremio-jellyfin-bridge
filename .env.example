# =============================================================================
#  STREMIO-JELLYFIN-BRIDGE — CONFIGURATION
# =============================================================================
#  This addon has TWO INDEPENDENT features. Enable either one on its own, or
#  both together:
#
#    1. LOCAL SUBTITLES — serve your own subtitle files for any title you play
#       in Stremio, matched by IMDb id. Works with or without Jellyfin.
#    2. JELLYFIN BRIDGE — browse and stream your local Jellyfin library in
#       Stremio (catalog, metadata, playback, native subtitles).
#
#  Both features are OPTIONAL. Copy this file to ".env" and enable what you
#  want. If you enable neither, the addon still starts but has nothing to serve.
# =============================================================================


# -----------------------------------------------------------------------------
#  FEATURE 1 — LOCAL SUBTITLES   (optional)
# -----------------------------------------------------------------------------
# Folder holding your own subtitle files. Setting this ENABLES the feature;
# leaving it unset disables it. Files are served independently of Jellyfin and
# matched to any title by IMDb id (Cinemeta, Jellyfin, or any other source).
#   Required: no      Default: unset (feature disabled)
#
# Layout is one folder per title, e.g.:
#   movie/tt0133093.The Matrix/eng.srt
#   series/tt0903747.Breaking Bad/S01E05.eng.srt
# Full folder & naming rules: subs/README.txt
#
# LOCAL_SUBS_DIR=/path/to/subtitles

# Shared secret for the subtitle WRITE endpoint (POST /local-subtitle). When
# set, write requests must echo it back in an X-Write-Secret header. Keep the
# endpoint LAN-only regardless.
#   Required: no      Default: unset (any LAN client may write)
#
# LOCAL_SUBS_WRITE_SECRET=some-long-random-string


# -----------------------------------------------------------------------------
#  FEATURE 2 — JELLYFIN BRIDGE   (optional; all-or-nothing)
# -----------------------------------------------------------------------------
# To ENABLE the bridge, set ALL THREE variables below. To disable it, leave ALL
# THREE unset. Setting only some of them is treated as a misconfiguration and
# the addon will refuse to start.
#   Required: as a group — all three, or none

# Your Jellyfin server URL (no trailing slash).
# JELLYFIN_URL=http://192.168.X.X:8096

# API key: Jellyfin Dashboard -> Advanced -> API Keys.
# JELLYFIN_API_KEY=your_api_key_here

# The Jellyfin user the bridge acts as.
# JELLYFIN_USER_NAME=your_username

# Show the Jellyfin catalog rows on Stremio's Discover page. Set to false to
# hide them while still using Jellyfin for search. (Jellyfin bridge only —
# ignored when the bridge is disabled.)
#   Required: no      Default: true
# SHOW_CATALOG=true


# -----------------------------------------------------------------------------
#  GENERAL   (optional)
# -----------------------------------------------------------------------------
# Fallback language code for subtitle files whose name doesn't specify one
# (applies to the Local Subtitles feature).
#   Required: no      Default: und      Examples: eng, heb, spa, fre
#   (Legacy name JELLYFIN_DEFAULT_EXT_SUBS_LANG is still honored if set.)
# DEFAULT_SUBS_LANG=eng

# Ports for the internal Node server.
#   Required: no      Defaults: 7000 (HTTP), 7001 (HTTPS)
PORT=7000
HTTPS_PORT=7001


# -----------------------------------------------------------------------------
#  DOCKER / SYSTEM   (optional; ignored when running natively)
# -----------------------------------------------------------------------------
# Container timezone (Region/City list:
#   https://en.wikipedia.org/wiki/List_of_tz_database_time_zones )
#   Required: no      Default: UTC
# TZ=America/New_York

# Run the container as this host user/group, so files the addon writes (e.g.
# via the subtitle WRITE endpoint) are owned by you rather than root. Find
# yours on the host with:  id -u  (PUID)   and   id -g  (PGID).
# The LOCAL_SUBS_DIR folder must be writable by this uid/gid.
#   Required: no      Default: 0:0 (root)
# PUID=1000
# PGID=1000
